#!/usr/bin/env bash
set -euo pipefail

staged_files="$(git diff --cached --name-only)"
if [ -z "$staged_files" ]; then
  exit 0
fi

if ! printf '%s\n' "$staged_files" | rg -q '^(bot|webapp|shared)/'; then
  exit 0
fi

if printf '%s\n' "$staged_files" | rg -q '^docs/exec-plans/(active|completed)/.+\.md$'; then
  exit 0
fi

cat >&2 <<'MSG'
ERROR: Missing execution plan update in staged changes.

You are committing code under bot/webapp/shared, but no plan file is staged in:
  docs/exec-plans/active/*.md or docs/exec-plans/completed/*.md

Fix:
  1) just start-task <task-id> title="..."
  2) update the plan file with allowed paths and permissions
  3) git add docs/exec-plans/...
  4) retry commit
MSG

exit 1
